[Unit]
Description=cannelloni client: vcan0 <-> caleon-canbus.local (UDP 20000)
Requires=vcan0.service
After=vcan0.service
BindsTo=vcan0.service
Wants=network-online.target avahi-daemon.service
After=network-online.target avahi-daemon.service

[Service]
Type=simple
ExecStart=/opt/caleon-canbus/client/cannelloni.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
