[Unit]
Description=Bring up vcan0 virtual CAN interface
After=systemd-modules-load.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/sbin/modprobe vcan
ExecStart=/bin/sh -c 'ip link show vcan0 >/dev/null 2>&1 || ip link add dev vcan0 type vcan'
ExecStart=/sbin/ip link set up vcan0
ExecStop=/sbin/ip link del vcan0

[Install]
WantedBy=multi-user.target
